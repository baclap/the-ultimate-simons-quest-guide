{
  "name": "cv2-guide-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "source \"$HOME/.cargo/env\" && wasm-pack build ../guide-map-wasm --target web --out-dir ../guide-map/src/wasm --no-pack",
